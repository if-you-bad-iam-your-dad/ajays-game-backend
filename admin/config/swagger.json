{
  "openapi": "3.0.0",
  "info": {
    "title": "Ajay's Game Backend API",
    "version": "1.0.0",
    "description": "Manual OpenAPI definition for Ajay's Game backend."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Users"
    },
    {
      "name": "Farmer"
    },
    {
      "name": "Logs"
    }
  ],
  "paths": {
    "/admin/users": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get all users",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserIdHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Users fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsersResponse"
                },
                "example": {
                  "message": "Users fetched successfully",
                  "data": [
                    {
                      "id": 1,
                      "email": "ravi.farmer@example.com",
                      "username": "ravi_farmer",
                      "role_id": 1,
                      "language": 1,
                      "status": "online",
                      "is_active": true
                    },
                    {
                      "id": 2,
                      "email": "priya.woman@example.com",
                      "username": "priya_woman",
                      "role_id": 2,
                      "language": 2,
                      "status": "offline",
                      "is_active": true
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "User id required or invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "user_id required (x-user-id header or user_id param)"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Error fetching users",
                  "error": "Database connection failed"
                }
              }
            }
          }
        }
      }
    },
    "/admin/users/register": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateRequest"
              },
              "example": {
                "email": "player@example.com",
                "username": "player_one",
                "password": "123456",
                "role_id": 1,
                "language": 1,
                "is_active": true,
                "status": "offline"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserCreatedResponse"
                },
                "example": {
                  "message": "User registered successfully",
                  "data": {
                    "id": 6,
                    "email": "player@example.com",
                    "username": "player_one",
                    "role_id": 1,
                    "language": 1,
                    "is_active": true,
                    "status": "offline"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Error registering user",
                  "error": "ER_DUP_ENTRY: Duplicate entry for email"
                }
              }
            }
          }
        }
      }
    },
    "/admin/users/login": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Login a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "admin@example.com",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User logged in successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                },
                "example": {
                  "message": "User logged in successfully",
                  "data": {
                    "id": 5,
                    "email": "admin@example.com",
                    "username": "super_admin",
                    "role_id": 5,
                    "language": 1,
                    "status": "online",
                    "is_active": true
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Invalid credentials"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "User not found"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Error logging in user",
                  "error": "Unexpected server error"
                }
              }
            }
          }
        }
      }
    },
