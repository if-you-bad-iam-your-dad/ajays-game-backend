                      "id": 1,
                      "role": "farmer",
                      "description": "Farmer role"
                    },
                    {
                      "id": 5,
                      "role": "admin",
                      "description": "Administrator with full access"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "User id required or invalid",
